# Supabase externo — integração preparada, mas desabilitada nesta etapa.
# Mantenha `mock` até o cliente real ser implementado e revisado.
VITE_SUPABASE_MODE=mock

# Chaves públicas do projeto Supabase externo.
# A anon key pode ser usada no navegador quando acompanhada de políticas RLS corretas.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Nunca adicione SUPABASE_SERVICE_ROLE_KEY em variáveis VITE_*.
# Segredos administrativos deverão existir somente no runtime de servidor.

# Opcional: habilita a síntese meteorológica com Gemini no servidor.
# Sem a chave, o sistema usa automaticamente o resumo determinístico.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
GEMINI_WEATHER_ENABLED=true
