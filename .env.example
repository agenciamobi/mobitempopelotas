# Supabase externo.
# Valores VITE_* são públicos e devem ficar em .env.production/.env.local, não no cofre de secrets do Lovable.
VITE_SUPABASE_MODE=mock
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Compatibilidade temporária com projetos que ainda usam a anon key legada.
VITE_SUPABASE_ANON_KEY=

# Overrides server-side opcionais para hosts que aceitam variáveis próprias.
# No Lovable, use o prefixo MOBI_ porque SUPABASE_* é reservado pela plataforma.
MOBI_SUPABASE_MODE=
MOBI_SUPABASE_URL=
MOBI_SUPABASE_PUBLISHABLE_KEY=

# Chave administrativa exclusiva do servidor. Nunca use prefixo VITE_* ou NEXT_PUBLIC_*.
MOBI_SUPABASE_SECRET_KEY=

# Compatibilidade com outros provedores de hospedagem.
SUPABASE_MODE=mock
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Protege rotas de captura, preenchimento do arquivo e resumo diário.
# Use um valor longo, aleatório e exclusivo do ambiente de produção.
CRON_SECRET=

# Web Push. Gere um único par VAPID e mantenha a chave privada somente no servidor.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@agenciamobi.com.br
# Segredo separado para disparos administrativos manuais.
PUSH_ADMIN_SECRET=

# Opcional: habilita a síntese meteorológica com Gemini no servidor.
# Sem a chave, o sistema usa automaticamente o resumo determinístico.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
GEMINI_WEATHER_ENABLED=true

# REDEMET/DECEA — todas as variáveis permanecem somente no runtime de servidor.
# A página mantém estado explícito de configuração pendente enquanto a chave estiver vazia.
REDEMET_API_KEY=
REDEMET_API_BASE_URL=https://api-redemet.decea.mil.br/
REDEMET_RADAR_AREA=cn
REDEMET_RADAR_PRODUCT=maxcappi

# Domínio público oficial. Canonical, sitemap e dados estruturados permanecem fixos neste host.
VITE_SITE_URL=https://tempopelotas.com.br
